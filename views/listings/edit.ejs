<% layout("layouts/boilerplate") %>
    <h1>Edit Listing</h1>
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
        <input type="text" name="title" value="<%= listing.title %>"><br><br>
        <input type="text" name="description" value="<%= listing.description %>"><br><br>
        <input type="text" name="price" value="<%= listing.price %>"><br><br>
        <input type="text" name="location" value="<%= listing.location %>"><br><br>
        <input type="text" name="country" value="<%= listing.country %>"><br><br>
        <input type="text" name="image[url]" value="<%= listing.image.url %>"><br><br>
        <button>Update</button>
    </form>