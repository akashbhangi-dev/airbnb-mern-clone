<% layout("layouts/boilerplate") %>
    <h2>Create New Listing</h2>
    <form method="POST" action="/listings">
        <input type="text" placeholder="title" name="title"><br><br>
        <input type="text" placeholder="description" name="description"><br><br>
        <input type="text" placeholder="price" name="price"><br><br>
        <input type="text" placeholder="image" name="image[url]"><br><br>
        <input type="text" placeholder="location" name="location"><br><br>
        <input type="text" placeholder="country" name="country"><br><br>
        <button>Submit</button>
    </form>